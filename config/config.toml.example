[game]
small_blind = 50
big_blind = 100
starting_stack = 2000
max_players = 6

[llm]
model = "gpt-4.1-mini"
api_key = "replace-with-real-api-key"
base_url = "https://api.openai.com/v1"
timeout = 60.0
# Optional. Leave this line commented out to avoid capping output tokens.
# max_output_tokens = 300
recent_hand_count = 5
thought_logging = "off"

[llm.openrouter]
# Optional. Applied only when llm.base_url points to openrouter.ai.
# sort = "throughput"

[coach]
enabled = false
model = "gpt-4.1-mini"
api_key = "replace-with-real-api-key"
base_url = "https://api.openai.com/v1"
timeout = 30.0
# Optional. Leave this line commented out to avoid capping output tokens.
# max_output_tokens = 300
recent_hand_count = 5

[coach.openrouter]
# Optional. Applied only when coach.base_url points to openrouter.ai.
# sort = "throughput"

[telegram]
bot_token = "replace-with-telegram-bot-token"
bot_username = "your_bot_username"
max_hands_per_table = 1

[web]
host = "127.0.0.1"
port = 8080
max_hands_per_table = 1
showdown_delay_seconds = 5.0
