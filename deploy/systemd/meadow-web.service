[Unit]
Description=Meadow web service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=meadow
Group=meadow
WorkingDirectory=/home/meadow/app
ExecStart=/home/meadow/app/.venv/bin/python -m meadow --config config/config.toml web
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
